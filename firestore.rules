rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function
    function isLider() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'lider';
    }
    function isAuth() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      allow read, write: if isLider();
    }

    match /records/{recordId} {
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow read:   if isAuth() && resource.data.uid == request.auth.uid;
      allow read, delete: if isLider();
    }

    match /metas/{metaId} {
      allow read:        if isAuth();
      allow write:       if isLider();
    }

    match /deleted_users/{uid} {
      allow read:  if isAuth();
      allow write: if isLider();
    }
  }
}
